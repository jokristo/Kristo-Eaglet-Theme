<div class="page-width">
  <div class="collection-header">
    <p class="section__kicker">{{ 'collections.general.all_collections' | t }}</p>
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="rte">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  {%- paginate collection.products by 24 -%}
    {%- if collection.products.size > 0 -%}
      <div class="product-grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center; padding:3rem 0;">{{ 'collections.general.no_products' | t }}</p>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
      <nav class="pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">&larr;</a>
        {%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="current">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">&rarr;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
