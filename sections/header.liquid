<header class="site-header">
  <div class="site-header__inner">
    <a href="{{ routes.root_url }}" class="site-header__logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="200" loading="eager">
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="site-header__actions">
      <a href="{{ routes.search_url }}">{{ 'general.search.search' | t }}</a>
      <a href="{{ routes.cart_url }}">
        {{ 'layout.cart.title' | t }}
        <span class="cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
      <button class="menu-toggle" aria-expanded="false" aria-label="{{ 'layout.navigation.menu' | t }}">&#9776;</button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
