<div class="page-width" style="padding-top:4rem; padding-bottom:4rem;">
  <div class="collection-header">
    <h1>{{ 'general.search.search' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
      >
      <button type="submit" class="btn btn--outline" style="border:none;">{{ 'general.search.search' | t }}</button>
    </form>
  </div>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p style="text-align:center; margin-bottom:2.5rem;">{{ 'general.search.results_for' | t: terms: search.terms }}</p>
      {%- paginate search.results by 24 -%}
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <div>
                <p class="product-card__title"><a href="{{ item.url }}">{{ item.title }}</a></p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <nav class="pagination">
            {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr;</a>{%- endif -%}
            {%- if paginate.next -%}<a href="{{ paginate.next.url }}">&rarr;</a>{%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p style="text-align:center;">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
